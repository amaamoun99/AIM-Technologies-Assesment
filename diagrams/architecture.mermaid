flowchart TD
    subgraph YouTubeAPI ["External Source"]
        API["YouTube Data API v3"]
    end

    subgraph DockerCompose ["Docker Compose Boundary"]
        subgraph AppService ["app container (running python main.py)"]
            Client["src/api_client.py<br>(YouTubeAPIClient)"]
            Pipeline["src/ingest.py<br>(IngestionPipeline)"]
            Transformer["src/transform.py<br>(VideoTransformer)"]
        end

        subgraph PostgresService ["postgres container"]
            DB["src/storage.py<br>(PostgreSQL Database)"]
        end

        subgraph VolumeMount ["Docker Volume / Host Bind Mount"]
            RawFiles["data/raw/<br>(JSON landing zone)"]
            CacheFile["data/channel_cache.json<br>(Handles Cache)"]
        end
    end

    subgraph UserInterface ["CLI & Analytics"]
        CLI["main.py --analyze"]
        Queries["queries/analysis.sql"]
    end

    Pipeline -->|1. Check Cache| CacheFile
    CacheFile -->|2. Hit: Use Cached ID| Pipeline
    Pipeline -->|2. Miss: Request API ID| Client
    Client -->|3. Query Handles| API
    API -->|4. Return UC ID| Client
    Client -->|5. Save to Cache| CacheFile
    
    API -->|6. Fetch Videos/Comments| Client
    Client -->|7. Raw JSON| Pipeline
    Pipeline -->|8. Save raw JSON| RawFiles
    Pipeline -->|9. Send raw data| Transformer
    Transformer -->|10. Dataclasses| Pipeline
    Pipeline -->|11. Load Batch| DB
    CLI -->|12. Runs reports| DB
    Queries -->|13. SQL Queries| CLI
